    "clean": "rm -rf .next .source content/docs/api"
  },
  "dependencies": {
    "fumadocs-core": "16.9.2",
    "fumadocs-mdx": "15.0.9",
    "fumadocs-ui": "16.9.2",
    "lucide-react": "^0.575.0",
    "next": "16.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "postcss": "8.5.15",
    "tailwindcss": "4.3.0",
    "typedoc": "0.28.19",
    "typedoc-plugin-frontmatter": "1.3.1",
    "typedoc-plugin-markdown": "4.11.0",
    "typescript": "~5.9.3"
  }
