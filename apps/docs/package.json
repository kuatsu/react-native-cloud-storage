{
  "name": "react-native-cloud-storage-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "fumadocs-mdx && next dev",
    "build": "fumadocs-mdx && next build",
    "start": "next start",
    "typecheck": "fumadocs-mdx && next typegen && tsc --noEmit",
